flowchart TD
    subgraph ASSESS["🔍 ALIGN Phase A — Assess"]
        A1["🌍 1. Ordinary World\n(Status Quo — the customer's current painful reality)\n\n📋 Tool: Narrative Coherence Scorecard™\nScore your messaging across 4 dimensions"]
        A2["📣 2. Call to Adventure\n(A triggering event forces recognition of the problem)\n\n🎤 Tool: Narrative Audit Interview Guide\nQ1–Q5: Uncover the exact trigger event & real competitor"]
    end

    subgraph LINK["🔗 ALIGN Phase L — Link"]
        L1["🚫 3. Refusal of the Call\n(Resistance to change: cost, disruption, uncertainty)\n\n📋 Tool: Strategic Narrative Blueprint™\nDefine the Villain that keeps the Hero stuck"]
        L2["🤝 4. Meeting the Mentor\n(The customer discovers your brand via content or referral)\n\n📋 Blueprint: Empathy + Authority\nYou understand their pain AND have the solution"]
    end

    subgraph INTEGRATE["⚙️ ALIGN Phase I — Integrate"]
        I1["🚪 5. Crossing the Threshold\n(First commitment: demo request, trial, or pilot)\n\n📊 Tool: Framework Selection Workbook\nChoose StoryBrand / Hero's Journey / Hybrid"]
        I2["⚔️ 6. Tests, Allies, Enemies\n(Internal politics, IT security concerns, champions)\n\n📖 Guide: Framework Comparison Matrix\nMap your Unique Mechanism to the right structure"]
    end

    subgraph GENERATE["✍️ ALIGN Phase G — Generate"]
        G1["🏔️ 7. Approach to the Cave\n(The biggest implementation challenge looms)\n\n📊 Tool: Content Narrative Matrix\nTop-of-funnel: Villain + Before State content"]
        G2["🔥 8. Ordeal\n(Overcoming the core obstacle: migration, change management)\n\nContent: Case studies, ROI calculators, objection handling"]
        G3["🏆 9. Reward\n(Initial success — the first win that validates the decision)\n\nContent: Testimonials, outcome stories, After State proof"]
    end

    subgraph NAVIGATE["📊 ALIGN Phase N — Navigate"]
        N1["🔄 10. The Road Back\n(Integration into daily operations and workflows)\n\n📈 Tool: Narrative KPI Dashboard\nLeading indicators: Time on Site, Scroll Depth"]
        N2["⚡ 11. Resurrection\n(Final challenge to full adoption and scale)\n\nLagging indicators: Sales Cycle Velocity, Win Rate"]
        N3["✨ 12. Return with the Elixir\n(Transformation complete — the customer becomes an advocate)\n\n🎤 Interview Guide Q16–Q20: Capture the After State story\nFeed it back into Phase A for the next narrative cycle"]
    end

    A1 --> A2 --> L1 --> L2 --> I1 --> I2 --> G1 --> G2 --> G3 --> N1 --> N2 --> N3

